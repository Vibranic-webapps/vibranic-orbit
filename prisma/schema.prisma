generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


enum Priority {
  EXTRA_SMALL
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum RecurrenceFrequency {
   DAILY
   WEEKLY
   MONTHLY
}

model Category {
  id             String                  @id @default(cuid())
  userId         String
  name           String
  icon           String
  color          String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  tasks          Task[]

  @@index([userId])
  @@unique([userId, name])
}

model TodoState {
  id             String                  @id @default(cuid())
  userId         String
  name           String
  color          String                  @default("#7C6CFF")
  order          Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  tasks          Task[]

  @@index([userId])
  @@unique([userId, name])
}

model Task {
  id             String                  @id @default(cuid())
  userId         String
  name           String
  description    String?
  startDateTime  DateTime?
  endDateTime    DateTime?
  priority       Priority                @default(MEDIUM)
  completed      Boolean                 @default(false)
  favorite       Boolean                 @default(false)
  categoryId     String?
  category       Category?               @relation(fields: [categoryId], references: [id])
  categoryRemoved Boolean                @default(false)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  frequency      RecurrenceFrequency?
  interval       Int                     @default(1)
  byWeekday      Int[]
  recurrenceEnd  DateTime?
  stateId        String?
  state          TodoState?              @relation(fields: [stateId], references: [id])
  order          Int                     @default(0)

  @@index([userId])
  @@index([categoryId])
  @@index([stateId])
}

model ColorPreset {
  id             String                  @id @default(cuid())
  userId         String
  color          String
  label          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId])
}
